# DTC - Variables de entorno
# Copiar este archivo como .env y ajustar los valores

# MySQL
DTC_DB_HOST=localhost
DTC_DB_PORT=3306
DTC_DB_NAME=dtc_market
DTC_DB_USER=dtc_user
DTC_DB_PASSWORD=tu_password_aqui
DTC_DB_ROOT_PASSWORD=root_password_seguro
DTC_DB_DRIVER=pymysql

# API autenticada: enviar header X-API-Key
DTC_API_KEYS=cambia-esta-api-key
DTC_API_PORT=8000

# Storage de fotos
# local guarda archivos en el volumen Docker app_data y los sirve por /media
DTC_STORAGE_BACKEND=local
DTC_LOCAL_STORAGE_DIR=/app/data/images
DTC_LOCAL_STORAGE_PUBLIC_BASE_URL=/media

# Google Cloud Storage opcional
# Para usar GCS: DTC_STORAGE_BACKEND=gcs y DTC_STORAGE_ENABLED=true
DTC_STORAGE_ENABLED=false
DTC_GCS_BUCKET=tu-bucket
DTC_GCS_PREFIX=market-monitor
# Opcional si sirves el bucket por CDN o dominio propio
DTC_GCS_PUBLIC_BASE_URL=

# Backups JSON locales
DTC_SAVE_JSON_BACKUP=true

# Scheduler diario dentro de Docker
TZ=America/Guatemala
DTC_DAILY_RUN_AT=03:15
DTC_RUN_ON_STARTUP=false

# Logging
DTC_LOG_LEVEL=INFO
