# DTC - Variables de entorno
# Copiar este archivo como .env y ajustar los valores

# MySQL
DTC_DB_HOST=localhost
DTC_DB_PORT=3306
DTC_DB_NAME=dtc_market
DTC_DB_USER=dtc_user
DTC_DB_PASSWORD=tu_password_aqui
DTC_DB_ROOT_PASSWORD=root_password_seguro
DTC_DB_DRIVER=pymysql

# API autenticada: enviar header X-API-Key
DTC_API_KEYS=cambia-esta-api-key
DTC_API_PORT=8000

# Fotos
# No se descargan ni se guardan archivos de imagen.
# Solo se persisten las URLs originales del sitio en raw_photos.

# Backups JSON locales
DTC_SAVE_JSON_BACKUP=true

# Scheduler diario dentro de Docker
TZ=America/Guatemala
DTC_DAILY_RUN_AT=03:15
DTC_RUN_ON_STARTUP=false
DTC_CRAUTOS_MAX_PAGES=5000
DTC_ENCUENTRA24_MAX_PAGES=5000

# Source Collector V2
DTC_INACTIVE_CONFIRM_SCANS=3
DTC_MIN_COVERAGE_RATIO=0.85
DTC_SAFETY_MIN_BASELINE=100
DTC_MAX_DETAIL_SCRAPES_PER_RUN=1000

# Logging
DTC_LOG_LEVEL=INFO
